<Window x:Class="Dice_Game.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="骰子比大小" Height="400" Width="500">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 結果顯示區 -->
            <RowDefinition Height="*"/>
            <!-- 骰子圖片區 -->
            <RowDefinition Height="Auto"/>
            <!-- 按鈕區 -->
        </Grid.RowDefinitions>

        <!-- 勝負結果顯示 -->
        <TextBlock x:Name="TxtResult" Grid.Row="0" Text="準備開始" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- 左右玩家區域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Player 1 -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Player 1" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <!-- 任務 A: 初始化預設載入 1.png -->
                <Image x:Name="ImgPlayer1" Source="/Images/1.png" Width="100" Height="100"/>
            </StackPanel>

            <!-- Player 2 -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Player 2" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <!-- 任務 A: 初始化預設載入 1.png -->
                <Image x:Name="ImgPlayer2" Source="/Images/1.png" Width="100" Height="100"/>
            </StackPanel>
        </Grid>

        <!-- 擲骰子按鈕 -->
        <Button Grid.Row="2" Content="擲骰子 (Roll)" FontSize="24" Height="50" Width="200" Click="BtnRoll_Click" Margin="0,20,0,0"/>
    </Grid>
</Window>
