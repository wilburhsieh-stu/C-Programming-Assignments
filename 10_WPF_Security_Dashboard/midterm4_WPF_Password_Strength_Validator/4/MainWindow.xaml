<Window x:Class="_4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_4"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="250">
                <TextBlock Text="請輸入密碼：" FontSize="16" Margin="0,0,0,10"/>
                <TextBox x:Name="TxtPasswordInput" FontSize="18" Height="30" Margin="0,0,0,20"/>
                <Button Content="確認密碼強度" FontSize="16" Height="40" Click="BtnCheckStrength_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
