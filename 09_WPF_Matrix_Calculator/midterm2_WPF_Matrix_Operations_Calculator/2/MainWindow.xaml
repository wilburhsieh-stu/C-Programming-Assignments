<Window x:Class="_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="[" FontSize="120" FontWeight="Light" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Grid VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Margin="10">
                        <TextBlock Text="⁴√" FontSize="20" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtA" Width="40" Height="30" FontSize="16" TextAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="8" Grid.Row="0" Grid.Column="1" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10"/>

                    <TextBox x:Name="txtB" Grid.Row="1" Grid.Column="0" Width="40" Height="30" FontSize="16" TextAlignment="Center" Margin="10"/>

                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Margin="10">
                        <TextBox x:Name="txtC" Width="40" Height="30" FontSize="16" TextAlignment="Center"/>
                        <TextBlock Text="³" FontSize="20" VerticalAlignment="Top"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="]" FontSize="120" FontWeight="Light" VerticalAlignment="Center" Margin="5,0,20,0"/>

                <TextBlock Text="[" FontSize="120" FontWeight="Light" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Grid VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="3" Grid.Row="0" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10"/>

                    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="10">
                        <TextBox x:Name="txtD" Width="40" Height="30" FontSize="16" TextAlignment="Center"/>
                        <TextBlock Text="½" FontSize="20" VerticalAlignment="Top"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="]" FontSize="120" FontWeight="Light" VerticalAlignment="Center" Margin="5,0,20,0"/>

                <TextBlock Text="=" FontSize="40" VerticalAlignment="Center" Margin="10,0,30,0"/>

                <TextBlock Text="[" FontSize="120" FontWeight="Light" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <StackPanel VerticalAlignment="Center" Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="x = " FontSize="24"/>
                        <TextBlock x:Name="txtResultX" Text="?" FontSize="24" Foreground="Red" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="y = " FontSize="24"/>
                        <TextBlock x:Name="txtResultY" Text="?" FontSize="24" Foreground="Blue" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="]" FontSize="120" FontWeight="Light" VerticalAlignment="Center" Margin="5,0,0,0"/>

            </StackPanel>

            <Button Grid.Row="1" Content="計算 x 與 y" Width="150" Height="40" FontSize="16" Click="BtnCalculate_Click" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </Grid>
    </Grid>
</Window>
